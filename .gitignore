# Dependencies
node_modules/
.pnp
.pnp.js

# Build output
dist/
build/
out/
.next/

# Test coverage
coverage/

# TypeScript
*.tsbuildinfo

# Lock files: pnpm-lock.yaml IS committed per subproject (backend/, frontend/)
# for reproducible installs - required by `pnpm install --frozen-lockfile` in
# both Dockerfiles and CI. Only ignore the other package managers' lockfiles,
# since this repo standardizes on pnpm.
package-lock.json
yarn.lock

# Environment & secrets — never commit real values
.env
.env.*
!.env.example

# Terraform
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# OS
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
logs/
npm-debug.log*
pnpm-debug.log*

# Misc
*.tgz
.cache/
tmp/
