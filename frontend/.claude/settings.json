{
  "permissions": {
    "allow": [
      "Bash(pnpm install)",
      "Bash(pnpm run dev)",
      "Bash(pnpm run build)",
      "Bash(pnpm run lint)",
      "Bash(pnpm run test:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Read(./.env)",
      "Read(./**/*.pem)"
    ]
  },
  "env": {
    "NODE_ENV": "development"
  }
}
