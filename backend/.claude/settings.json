{
  "permissions": {
    "allow": [
      "Bash(pnpm install)",
      "Bash(pnpm install *)",
      "Bash(pnpm run build)",
      "Bash(pnpm run typecheck)",
      "Bash(pnpm run format)",
      "Bash(pnpm run lint)",
      "Bash(pnpm run start:dev)",
      "Bash(pnpm run start:debug)",
      "Bash(pnpm run test)",
      "Bash(pnpm run test:watch)",
      "Bash(pnpm run test:cov)",
      "Bash(pnpm run test:e2e)",
      "Bash(tsc --noEmit)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git stash list)",
      "Bash(npx typeorm migration:generate *)",
      "Bash(npx typeorm migration:show *)",
      "Bash(npx typeorm schema:log *)",
      "Bash(docker compose up -d *)",
      "Bash(docker compose ps)",
      "Bash(docker compose logs *)",
      "Bash(find src *)",
      "Bash(grep -r *)",
      "Bash(cat package.json)"
    ],
    "ask": [
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(git merge *)",
      "Bash(npx typeorm migration:run *)",
      "Bash(npx typeorm migration:revert *)",
      "Bash(docker compose down *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -f *)",
      "Bash(psql *)",
      "Bash(aws secretsmanager delete-secret *)",
      "Read(./.env)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)"
    ]
  },
  "env": {
    "NODE_ENV": "development"
  }
}
