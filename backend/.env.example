# Backend environment variables
# Copy to .env — NEVER commit .env with real values
#
# Generate JWT_SECRET:  openssl rand -hex 32
# Generate POSTGRES_PASSWORD: openssl rand -hex 16

# ---- Database ----
# When running via docker-compose:
DATABASE_URL=postgres://scribe:CHANGE_ME@localhost:5432/clinical_scribe

# Password used by docker-compose postgres service (must match DATABASE_URL)
POSTGRES_PASSWORD=CHANGE_ME

# ---- Auth ----
JWT_SECRET=CHANGE_ME_use_openssl_rand_hex_32

# ---- App (optional) ----
PORT=3000
CORS_ORIGIN=http://localhost:5173,http://localhost:3001

# ---- Demo credentials (read-only reference — actual values in seed-data.ts) ----
# dr.alice@demo.clinic  / DemoPass1!   (provider)
# dr.bob@demo.clinic    / DemoPass2!   (provider)
# dr.carol@demo.clinic  / DemoPass3!   (provider)
# admin@demo.clinic     / AdminPass1!  (admin)
