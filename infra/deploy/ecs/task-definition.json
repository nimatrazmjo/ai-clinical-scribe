{
  "family": "${TASK_FAMILY}",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["EC2"],
  "cpu": "1024",
  "memory": "1536",
  "executionRoleArn": "${EXECUTION_ROLE_ARN}",
  "taskRoleArn": "${TASK_ROLE_ARN}",
  "containerDefinitions": [
    {
      "name": "web",
      "image": "${WEB_IMAGE}",
      "essential": true,
      "memoryReservation": 256,
      "portMappings": [{ "containerPort": 80, "protocol": "tcp" }],
      "dependsOn": [{ "containerName": "api", "condition": "START" }],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/acs/prod/web",
          "awslogs-region": "${AWS_REGION}",
          "awslogs-stream-prefix": "web",
          "awslogs-create-group": "true"
        }
      }
    },
    {
      "name": "api",
      "image": "${API_IMAGE}",
      "essential": true,
      "memoryReservation": 768,
      "portMappings": [{ "containerPort": 3000, "protocol": "tcp" }],
      "environment": [
        { "name": "NODE_ENV", "value": "production" },
        { "name": "PORT", "value": "3000" },
        { "name": "RUN_MIGRATIONS", "value": "false" }
      ],
      "secrets": [
        { "name": "DATABASE_URL", "valueFrom": "${DATABASE_URL_ARN}" },
        { "name": "ANTHROPIC_API_KEY", "valueFrom": "${ANTHROPIC_API_KEY_ARN}" },
        { "name": "JWT_SECRET", "valueFrom": "${JWT_SECRET_ARN}" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/acs/prod/api",
          "awslogs-region": "${AWS_REGION}",
          "awslogs-stream-prefix": "api",
          "awslogs-create-group": "true"
        }
      }
    }
  ]
}
